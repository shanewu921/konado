; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[accessibility]

general/accessibility_support=2

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Konado Project"
config/description="Konado is a dialogue creation toolkit for the Godot Engine, with templates and a dialogue manager to help you quickly build Visual Novels, Gal Games, RPGs and other story‑driven projects."
config/version="2.4.2"
run/main_scene="uid://bcl2e6o0kb5dm"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
boot_splash/image="uid://bqg62jaajvjx4"
config/icon="uid://b5olx2vwoscbr"
boot_splash/minimum_display_time=500

[autoload]

KonadoAPI="*uid://ptylvcqylq7j"
KND_AchievementManager="*uid://dlhxd0ixnuo6i"
KND_WebTool="*uid://b4rup11rlc0uk"
KND_Settings="*uid://crc32ueqs8u1w"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="viewport"

[dotnet]

project/assembly_name="Konado"

[editor_plugins]

enabled=PackedStringArray("res://addons/konado/plugin.cfg", "res://addons/konado_achievement/plugin.cfg", "res://addons/konado_settings/plugin.cfg", "res://addons/konado_webtool/plugin.cfg")

[internationalization]

locale/locale_filter_mode=1

[rendering]

textures/vram_compression/import_etc2_astc=true
